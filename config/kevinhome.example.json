{
  "environment": "kevinhome",
  "dataDir": "/data",
  "ai": {
    "enabled": true,
    "provider": "gemini",
    "model": "gemini-2.5-flash",
    "timeoutMs": 20000
  },
  "ruleSources": [
    {
      "name": "homelab-docs",
      "path": "/rules/homelab-docs",
      "required": true,
      "entryFiles": [
        "AGENTS.md",
        "AGENT_RULES.md",
        "kevin-ai-persona/PERSONA.md"
      ]
    }
  ],
  "repositories": [
    {
      "name": "kevin-autopilot",
      "path": "/repos/homeproject/kevin-autopilot"
    },
    {
      "name": "homelab-docs",
      "path": "/repos/homeproject/homelab-docs"
    }
  ],
  "services": [
    {
      "name": "Portainer",
      "domain": "portainer.sisihome.org",
